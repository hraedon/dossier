# suite.env — shared suite configuration (Plan 014 WI-1.5 team deploy).
#
# Copy to `suite.env` and replace the placeholder values. `suite.env` is
# gitignored and MUST NEVER be committed — it carries the DSN, key path, and
# (optionally) the LDAP bind password for the whole suite.
#
# Precedence (blueprint §2.1): process env > suite.env > tool default.
# Anything set in the process environment overrides the value here.
#
# This file carries PLACEHOLDERS ONLY. No real work-domain identifier, host,
# account, or secret belongs here.

# ── Suite-wide spine config (regista Plan 025 WI-1.1) ─────────────────────
# The canonical names shared across every suite component. The DOSSIER_*
# aliases still work but are deprecated — migrate by using these.
REGISTA_DSN=postgresql://dossier:replace-me@suite-db.example:5432/dossier
REGISTA_KEY_PATH=/run/secrets/dossier-keys.json
# Either value above may be a secret-backend ref instead of a literal:
#   env:VAR_NAME          — resolved from the process env at startup
#   file:/path/to/secret   — read from a file at startup
#   vault:mount/path/key   — fetched from HashiCorp Vault (needs regista[vault])
#   azure:secret-name      — fetched from Azure Key Vault (needs regista[azure])
# A literal DSN / bare key path passes through unchanged (no backend contact).

# ── dossier project fronting ──────────────────────────────────────────────
DOSSIER_PROJECT=dossier                       # default regista project/schema
DOSSIER_PROJECTS=dossier                       # comma-separated list of projects to front

# ── Session + cookie security ─────────────────────────────────────────────
DOSSIER_SESSION_SECRET=replace-with-a-long-random-secret-at-least-32-chars
DOSSIER_SECURE_COOKIES=true                    # false only for local dev without TLS

# ── Auth / identity source (blueprint §2.6) ───────────────────────────────
# local = JSON users file (dev/small teams); ldap = the workplace directory.
DOSSIER_AUTH_BACKEND=ldap
DOSSIER_USERS_PATH=/run/secrets/users.json     # used only when AUTH_BACKEND=local

# ── LDAP / Active Directory (the one-workplace identity source) ────────────
# All values are env-driven; the bind password is never committed — source it
# from the secret backend (env:/vault:/azure:) or set it in the process env.
DOSSIER_LDAP_SERVER=ldaps://dc1.WORK-DOMAIN:636,ldaps://dc2.WORK-DOMAIN:636
DOSSIER_LDAP_BASE_DN=DC=WORK-DOMAIN
DOSSIER_LDAP_BIND_DN=CN=svc-dossier,OU=Service Accounts,DC=WORK-DOMAIN
DOSSIER_LDAP_BIND_PASSWORD=env:DOSSIER_LDAP_BIND_PASSWORD
DOSSIER_LDAP_DOMAIN=WORK-DOMAIN
DOSSIER_LDAP_USER_FILTER=(&(objectClass=user)(sAMAccountName={login}))
DOSSIER_LDAP_GROUP_STRATEGY=direct
DOSSIER_LDAP_CA_CERT_FILE=/run/secrets/ldap/ad-root-ca.pem
DOSSIER_LDAP_CONNECT_TIMEOUT=5

# ── TLS termination (the team-deploy posture) ─────────────────────────────
# When both are set, uvicorn serves over TLS. When both unset, plain HTTP.
# Provision the cert+key on the host or mount them in the container deploy.
DOSSIER_TLS_CERT_PATH=/run/secrets/tls/cert.pem
DOSSIER_TLS_KEY_PATH=/run/secrets/tls/key.pem

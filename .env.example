# Copy this file to .env and replace placeholder values before running dossier.
# .env is gitignored and must never be committed.
#
# ── Suite-wide config (blueprint §2.1) ────────────────────────────────────
# dossier reads $AGENT_SUITE_CONFIG (default ~/.config/agent-suite/suite.env)
# on startup and injects any keys not already set in the process environment.
# Precedence: process env > suite.env > tool default. This means you can set
# REGISTA_DSN / REGISTA_KEY_PATH once in suite.env and every suite component
# picks it up.
#
# Suite-wide vars (Plan 013 WI-1.1): REGISTA_DSN / REGISTA_KEY_PATH are the
# canonical names shared across the suite. The DOSSIER_* aliases still work
# but emit a deprecation warning — migrate by switching your env.

REGISTA_DSN=postgresql://dossier:changeme@localhost:5432/dossier  # Postgres DSN (canonical; was DOSSIER_DATABASE_URL)
REGISTA_KEY_PATH=/run/secrets/dossier-keys.json                    # HMAC keyset path (canonical; was DOSSIER_HMAC_KEY_PATH)
# Either of the above may be a secret-backend ref instead of a literal:
#   env:VAR_NAME              — resolved from the process env at startup
#   file:/path/to/secret      — read from a file at startup
#   vault:mount/path/to/key    — fetched from HashiCorp Vault (needs regista[vault])
#   azure:secret-name         — fetched from Azure Key Vault (needs regista[azure])
# A literal DSN / bare key path passes through unchanged (no backend contact).
# Resolution failures fail loudly (doctor, init, serve) — they never degrade to
# a bogus DSN. See Plan 013 WI-4.1 and src/dossier/secrets.py for the contract.
DOSSIER_PROJECT=dossier                                            # default regista project/schema name (used when DOSSIER_PROJECTS is not set)
DOSSIER_PROJECTS=dossier                                            # comma-separated list of projects to front (Plan 011); defaults to DOSSIER_PROJECT
DOSSIER_SESSION_SECRET=replace-with-a-long-random-secret           # itsdangerous signed-cookie secret
DOSSIER_SESSION_MAX_AGE_SECONDS=43200                              # signed session cookie lifetime (seconds)
DOSSIER_SECURE_COOKIES=true                                        # false only for local dev without TLS
DOSSIER_REQUIRE_SSL=false                                          # set true when regista must require TLS to Postgres
DOSSIER_USERS_PATH=/etc/dossier/users.json                         # path to the local users JSON file (LocalBackend)
DOSSIER_AUTH_BACKEND=local                                         # auth backend; "local" or "ldap" (Plan 003)
DOSSIER_PASSWORD_SCRYPT_N=131072                                   # scrypt N parameter for password hashing (must be a power of 2, >= 2)

# ── Project access control (Plan 014 v1.1/v1.5) ─────────────────────────
# open    — compatibility posture: every authenticated principal can read all projects (doctor warn)
# audit   — load ACL and log would-be denials, but continue allowing access (doctor warn)
# enforce — default-deny; only explicit project/admin grants are readable (doctor ok)
DOSSIER_PROJECT_ACCESS_MODE=open
# Required for audit/enforce. Mount an operator-owned, non-writable policy file;
# start from project-acl.example.json. Policy changes take effect after restart.
# DOSSIER_PROJECT_ACL_PATH=/etc/dossier/project-acl.json

# ── TLS termination (Plan 014 WI-1.5) ────────────────────────────────────
# When both are set, uvicorn serves over TLS (the team-deploy posture).
# When both are unset, plain HTTP (local dev). Setting only one is an error.
# No certificate is ever committed — provision these on the host or mount a
# secret in the container deploy. See docs/deploy.md.
# DOSSIER_TLS_CERT_PATH=/run/secrets/tls/cert.pem
# DOSSIER_TLS_KEY_PATH=/run/secrets/tls/key.pem

# ── LDAP / Active Directory (required only when DOSSIER_AUTH_BACKEND=ldap) ──
# DOSSIER_LDAP_SERVER=ldaps://dc1.example.com:636,ldaps://dc2.example.com:636  # comma-separated LDAPS URLs (multi-DC failover)
# DOSSIER_LDAP_BASE_DN=DC=example,DC=com                                    # search base for user lookup
# DOSSIER_LDAP_BIND_DN=CN=svc-dossier,OU=Service Accounts,DC=example,DC=com  # least-privilege read-only bind account
# DOSSIER_LDAP_BIND_PASSWORD=                                              # bind password (env or Vault; never committed)
# DOSSIER_LDAP_DOMAIN=example.com                                          # appears in Principal.source as "ldap:example.com"
# DOSSIER_LDAP_USER_FILTER=(&(objectClass=user)(sAMAccountName={login}))   # {login} is replaced with the submitted username
# DOSSIER_LDAP_GROUP_STRATEGY=direct                                       # "direct" (memberOf) or "nested" (LDAP_MATCHING_RULE_IN_CHAIN recursive search)
# DOSSIER_LDAP_CA_CERT_FILE=                                              # path to the AD root CA PEM (pinning; never validate=NONE)
# DOSSIER_LDAP_CONNECT_TIMEOUT=5                                          # connection timeout in seconds

# ── Notifications (Plan 018 WI-2.1) ──────────────────────────────────────
# dossier emits notification-worthy occurrences (gate-blocking transitions)
# to a webhook sink. agent-wake's ingress is one valid target; a bare webhook
# receiver is another. When unset, notifications are not delivered and the
# doctor reports a `warn` — no error.
# DOSSIER_NOTIFICATION_SINK=http://localhost:9090/ingest                  # webhook URL for notification events
# DOSSIER_NOTIFICATION_SECRET_REF=env:DOSSIER_WAKE_SECRET                  # shared HMAC key; use a backend ref, not plaintext
# DOSSIER_NOTIFICATION_SOURCE=dossier                                     # must match agent-wake's configured source name
# DOSSIER_NOTIFICATION_IDENTITY=service:dossier                            # optional X-AgentWake-Identity for source allowlisting
# DOSSIER_BASE_URL=https://dossier.example.com                             # base URL for deep links in notifications
